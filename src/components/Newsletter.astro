---
---

<section class="newsletter" aria-labelledby="newsletter-heading">
  <div class="container newsletter-inner">
    <div class="newsletter-icon" aria-hidden="true">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
        <polyline points="22,6 12,13 2,6"/>
      </svg>
    </div>
    <div class="newsletter-text">
      <h2 id="newsletter-heading" class="newsletter-heading">Get the next postcard.</h2>
      <p>New stories, recommended reads, and travel notes — delivered whenever I remember to send them.</p>
    </div>
    <form class="newsletter-form" id="newsletter-form">
      <label for="email-input" class="sr-only">Your email address</label>
      <input
        id="email-input"
        type="email"
        name="email"
        placeholder="your@email.com"
        autocomplete="email"
        required
        class="newsletter-input"
      />
      <button type="submit" class="btn btn-primary">Subscribe</button>
    </form>
    <p class="newsletter-note" id="newsletter-note">No spam. Unsubscribe anytime.</p>
  </div>
</section>

<script>
  const form = document.getElementById("newsletter-form") as HTMLFormElement;
  const note = document.getElementById("newsletter-note")!;
  const button = form.querySelector("button") as HTMLButtonElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const email = (new FormData(form).get("email") as string);
    button.disabled = true;
    button.textContent = "Sending...";

    const callbackName = "mc_" + Date.now();

    try {
      const result = await new Promise<{result: string; msg: string}>((resolve, reject) => {
        const timeout = setTimeout(() => { cleanup(); reject(new Error("Timeout")); }, 10000);

        function cleanup() {
          clearTimeout(timeout);
          delete (window as any)[callbackName];
          script.remove();
        }

        (window as any)[callbackName] = (data: any) => { cleanup(); resolve(data); };

        const params = new URLSearchParams({
          u: "29c888b46264944c8ffe75161",
          id: "840f69c1a6",
          EMAIL: email,
          c: callbackName,
        });

        const script = document.createElement("script");
        script.src = `https://us7.list-manage.com/subscribe/post-json?${params}`;
        script.onerror = () => { cleanup(); reject(new Error("Network error")); };
        document.head.appendChild(script);
      });

      note.textContent = result.result === "success"
        ? "Subscribed!"
        : result.msg.replace(/^\d+ - /, "");
      if (result.result === "success") form.reset();
    } catch {
      note.textContent = "Something went wrong. Please try again.";
    } finally {
      button.disabled = false;
      button.textContent = "Subscribe";
    }
  });
</script>

<style>
  .newsletter {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .newsletter-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-rows: auto auto;
    align-items: center;
    gap: 1rem 2rem;
    padding-block: 3.5rem;
  }

  /* Icon */
  .newsletter-icon {
    grid-row: 1 / 3;
    width: 60px;
    height: 60px;
    background: var(--color-accent);
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /* Text block */
  .newsletter-text {
    grid-column: 2;
    grid-row: 1;
  }

  .newsletter-heading {
    font-family: var(--font-heading);
    font-size: clamp(1.2rem, 2vw, 1.6rem);
    font-weight: 600;
    margin-bottom: 0.3rem;
  }

  .newsletter-text p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    max-width: 50ch;
  }

  /* Form */
  .newsletter-form {
    grid-column: 3;
    grid-row: 1;
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .newsletter-input {
    font-family: var(--font-body);
    font-size: 0.95rem;
    padding: 0.65em 1em;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    color: var(--color-text);
    width: 230px;
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
  }

  .newsletter-input::placeholder {
    color: var(--color-text-muted);
    opacity: 0.7;
  }

  .newsletter-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(196, 113, 58, 0.15);
  }

  /* Fine print */
  .newsletter-note {
    grid-column: 3;
    grid-row: 2;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-align: right;
  }

  /* Visually hidden label */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  @media (max-width: 820px) {
    .newsletter-inner {
      grid-template-columns: auto 1fr;
      grid-template-rows: auto auto auto;
    }

    .newsletter-form {
      grid-column: 1 / 3;
      grid-row: 2;
    }

    .newsletter-note {
      grid-column: 1 / 3;
      grid-row: 3;
      text-align: left;
    }

    .newsletter-icon {
      grid-row: 1;
    }

    .newsletter-input {
      width: 100%;
      flex: 1;
    }
  }

  @media (max-width: 480px) {
    .newsletter-form {
      flex-direction: column;
    }
  }
</style>
