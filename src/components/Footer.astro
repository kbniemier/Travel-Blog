<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo">Footnotes <em>&</em> Footsteps</a>
      <p class="footer-tagline">History from the road — stories written slowly, lived fully.</p>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/articles">Articles</a></li>
      </ul>
    </nav>

  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {new Date().getFullYear()} Footnotes &amp; Footsteps. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    padding-block: 3.5rem;
    align-items: start;
  }

  /* Brand */
  .footer-logo {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    display: block;
    margin-bottom: 0.5rem;
  }

  .footer-logo em {
    font-style: italic;
    color: var(--color-accent);
  }

  .footer-tagline {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    max-width: 28ch;
  }

  /* Nav */
  .footer-nav ul {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    list-style: none;
  }

  .footer-nav a {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-nav a:hover {
    color: var(--color-accent);
  }

  /* Social */
  .footer-social-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .social-links {
    display: flex;
    gap: 0.75rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--color-surface-2);
    color: var(--color-text-muted);
    transition: background 0.2s, color 0.2s;
  }

  .social-link:hover {
    background: var(--color-accent);
    color: #fff;
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid var(--color-border);
    padding-block: 1rem;
  }

  .footer-bottom p {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-align: center;
  }

  @media (max-width: 680px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding-block: 2.5rem;
    }
  }
</style>
