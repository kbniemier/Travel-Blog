---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo">Footnotes <em>&</em> Footsteps</a>
      <p class="footer-tagline">History from the road — stories written slowly, lived fully.</p>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/articles">Articles</a></li>
      </ul>
    </nav>

    <div class="footer-social">
      <p class="footer-social-label">Find me on</p>
      <div class="social-links">
        <!-- Instagram -->
        <a href="#" aria-label="Instagram" class="social-link" rel="noopener noreferrer" target="_blank">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
          </svg>
        </a>
        <!-- Twitter / X -->
        <a href="#" aria-label="X (Twitter)" class="social-link" rel="noopener noreferrer" target="_blank">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <!-- Pinterest -->
        <a href="#" aria-label="Pinterest" class="social-link" rel="noopener noreferrer" target="_blank">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.04-2.83.18-.74 1.22-5.16 1.22-5.16s-.31-.62-.31-1.54c0-1.45.84-2.53 1.88-2.53.89 0 1.32.67 1.32 1.47 0 .9-.57 2.24-.87 3.48-.25 1.04.52 1.88 1.54 1.88 1.85 0 3.28-1.95 3.28-4.77 0-2.49-1.79-4.23-4.35-4.23-2.96 0-4.7 2.22-4.7 4.51 0 .89.34 1.85.77 2.37.08.1.09.19.07.29-.08.33-.26 1.04-.29 1.18-.05.19-.16.23-.37.14-1.39-.65-2.26-2.68-2.26-4.32 0-3.51 2.55-6.74 7.36-6.74 3.86 0 6.86 2.75 6.86 6.42 0 3.83-2.41 6.9-5.76 6.9-1.12 0-2.18-.58-2.54-1.27l-.69 2.59c-.25.96-.93 2.17-1.39 2.9.05.16.1.31.15.47A10 10 0 0 0 22 12c0-5.52-4.48-10-10-10z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {new Date().getFullYear()} Footnotes &amp; Footsteps. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 3rem;
    padding-block: 3.5rem;
    align-items: start;
  }

  /* Brand */
  .footer-logo {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    display: block;
    margin-bottom: 0.5rem;
  }

  .footer-logo em {
    font-style: italic;
    color: var(--color-accent);
  }

  .footer-tagline {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    max-width: 28ch;
  }

  /* Nav */
  .footer-nav ul {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    list-style: none;
  }

  .footer-nav a {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-nav a:hover {
    color: var(--color-accent);
  }

  /* Social */
  .footer-social-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .social-links {
    display: flex;
    gap: 0.75rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--color-surface-2);
    color: var(--color-text-muted);
    transition: background 0.2s, color 0.2s;
  }

  .social-link:hover {
    background: var(--color-accent);
    color: #fff;
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid var(--color-border);
    padding-block: 1rem;
  }

  .footer-bottom p {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-align: center;
  }

  @media (max-width: 680px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding-block: 2.5rem;
    }
  }
</style>
