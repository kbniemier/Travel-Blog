---
---

<section class="hero" aria-label="Welcome">
  <div class="hero-bg"></div>
  <div class="hero-overlay"></div>
  <div class="container hero-content">
    <p class="hero-eyebrow">A travel journal</p>
    <h1 class="hero-title">
      Histories from<br />
      <em>the road.</em>
    </h1>
    <p class="hero-subtitle">
      Jetsetting and vagabonding through Ancient Ruins, Medieval Cathedrals, Battlegrounds, and more.
      Each place touched by history. Take the first step with me.
    </p>
    <div class="hero-actions">
      <a href="/blog" class="btn btn-primary">Read the blog</a>
      <a href="/about" class="btn btn-outline-light">About me</a>
    </div>
  </div>

  <div class="hero-scroll-hint" aria-hidden="true">
    <svg width="20" height="28" viewBox="0 0 20 28" fill="none">
      <rect x="1" y="1" width="18" height="26" rx="9" stroke="rgba(255,255,255,0.6)" stroke-width="1.5"/>
      <circle class="scroll-dot" cx="10" cy="8" r="3" fill="rgba(255,255,255,0.8)"/>
    </svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    color: #fff;
  }

  /* Background photo — warm landscape via Unsplash */
  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('https://images.unsplash.com/photo-1552832230-c0197dd311b5?w=1600&q=85');
    background-size: cover;
    background-position: center 60%;
    transform: scale(1.03);
    transition: transform 8s ease;
  }

  .hero:hover .hero-bg {
    transform: scale(1);
  }

  /* Overlay: warm dark gradient from bottom */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(28, 15, 5, 0.35) 0%,
      rgba(28, 15, 5, 0.55) 60%,
      rgba(28, 15, 5, 0.75) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 760px;
    padding-block: 8rem 4rem;
  }

  .hero-eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 220, 180, 0.85);
    margin-bottom: 1.25rem;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 700;
    line-height: 1.1;
    color: #fff;
    text-shadow: 0 2px 20px rgba(0,0,0,0.35);
    margin-bottom: 1.25rem;
  }

  .hero-title em {
    font-style: italic;
    color: #F5C996;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: rgba(255, 245, 230, 0.88);
    max-width: 52ch;
    margin: 0 auto 2.25rem;
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-outline-light {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.65em 1.5em;
    border-radius: var(--radius-md);
    border: 2px solid rgba(255, 255, 255, 0.6);
    color: #fff;
    background: transparent;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
  }

  .btn-outline-light:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: #fff;
    transform: translateY(-1px);
  }

  /* Scroll hint */
  .hero-scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    opacity: 0.7;
  }

  .scroll-dot {
    animation: scrollBounce 2s ease-in-out infinite;
  }

  @keyframes scrollBounce {
    0%, 100% { transform: translateY(0); opacity: 0.8; }
    50% { transform: translateY(8px); opacity: 0.3; }
  }
</style>
